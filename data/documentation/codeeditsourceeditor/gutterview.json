nd":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GutterView","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the gutter needs more space (when the number of digits in the numbers increases eg. adding a line after line 99),"},{"text":" ","type":"text"},{"type":"text","text":"it will notify it’s delegate via the "},{"isActive":true,"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterViewDelegate\/gutterViewWidthDidUpdate(newWidth:)","type":"reference"},{"type":"text","text":" method. In"},{"text":" ","type":"text"},{"type":"codeVoice","code":"SourceEditor"},{"type":"text","text":", this notifies the "},{"type":"reference","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/TextViewController","isActive":true},{"text":", which in turn updates the textview’s edge insets","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to adjust for the new leading inset."}]},{"inlineContent":[{"type":"text","text":"This view also listens for selection updates, and draws a selected background on selected lines to keep the illusion"},{"type":"text","text":" "},{"text":"that the gutter’s line numbers are inline with the line itself.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The gutter view has insets of it’s own that are relative to the widest line index. By default, these insets are 20px"},{"type":"text","text":" "},{"type":"text","text":"leading, and 12px trailing. However, this view also has a "},{"type":"codeVoice","code":"GutterView\/backgroundEdgeInsets"},{"type":"text","text":" property, that pads"},{"type":"text","text":" "},{"text":"the rect that has a background drawn. This allows the text to be scrolled under the gutter view for 8px before being","type":"text"},{"type":"text","text":" "},{"type":"text","text":"overlapped by the gutter. It should help the textview keep the cursor visible if the user types while the cursor is"},{"text":" ","type":"text"},{"type":"text","text":"off the leading edge of the editor."}]}]}],"kind":"symbol","abstract":[{"text":"The gutter view displays line numbers that match the text view’s line indexes.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This view is used as a scroll view’s ruler view. It sits on top of the text view so text scrolls underneath the"},{"text":" ","type":"text"},{"type":"text","text":"gutter if line wrapping is disabled."}],"references":{"doc://codeeditsourceeditor.CodeEditSourceEditor/objc(pl)NSDraggingDestination":{"type":"unresolvable","title":"AppKit.NSDraggingDestination","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/objc(pl)NSDraggingDestination"},"doc://codeeditsourceeditor.CodeEditSourceEditor/s28CustomDebugStringConvertibleP":{"type":"unresolvable","title":"Swift.CustomDebugStringConvertible","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/s28CustomDebugStringConvertibleP"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/GutterView/init(font:textColor:selectedTextColor:textView:delegate:)":{"type":"topic","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"font"},{"kind":"text","text":": "},{"text":"NSFont","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSFont"},{"kind":"text","text":", "},{"text":"textColor","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"NSColor","preciseIdentifier":"c:objc(cs)NSColor"},{"text":", ","kind":"text"}