{"variants":[{"paths":["\/documentation\/codeeditsourceeditor\/gutterview"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"GutterView"}],"symbolKind":"class","role":"symbol","roleHeading":"Class","navigatorTitle":[{"text":"GutterView","kind":"identifier"}],"title":"GutterView","externalID":"c:@M@CodeEditSourceEditor@objc(cs)GutterView","modules":[{"name":"CodeEditSourceEditor"}]},"hierarchy":{"paths":[["doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor"]]},"kind":"symbol","abstract":[{"text":"The gutter view displays line numbers that match the text view’s line indexes.","type":"text"},{"type":"text","text":" "},{"text":"This view is used as a scroll view’s ruler view. It sits on top of the text view so text scrolls underneath the","type":"text"},{"text":" ","type":"text"},{"text":"gutter if line wrapping is disabled.","type":"text"}],"seeAlsoSections":[{"title":"Text View","identifiers":["doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/CodeEditSourceEditor","doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/TextViewController"],"generated":true}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterView","interfaceLanguage":"swift"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterView\/init(font:textColor:textView:delegate:)"]},{"title":"Instance Properties","identifiers":["doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterView\/gutterWidth","doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterView\/isFlipped"]},{"title":"Instance Methods","identifiers":["doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterView\/draw(_:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"GutterView","kind":"identifier"}]}]},{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"text":"If the gutter needs more space (when the number of digits in the numbers increases eg. adding a line after line 99),","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it will notify it’s delegate via the "},{"identifier":"doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterViewDelegate\/gutterViewWidthDidUpdate(newWidth:)","type":"reference","isActive":true},{"type":"text","text":" method. In"},{"text":" ","type":"text"},{"code":"CodeEditSourceEditor","type":"codeVoice"},{"type":"text","text":", this notifies the "},{"identifier":"doc:\/\/CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/TextViewController","isActive":true,"type":"reference"},{"type":"text","text":", which in turn updates the textview’s edge insets"},{"type":"text","text":" "},{"text":"to adjust for the new leading inset.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This view also listens for selection updates, and draws a selected background on selected lines to keep the illusion","type":"text"},{"type":"text","text":" "},{"text":"that the gutter’s line numbers are inline with the line itself.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The gutter view has insets of it’s own that are relative to the widest line index. By default, these insets are 20px"},{"type":"text","text":" "},{"text":"leading, and 12px trailing. However, this view also has a ","type":"text"},{"code":"GutterView\/backgroundEdgeInsets","type":"codeVoice"},{"text":" property, that pads","type":"text"},{"type":"text","text":" "},{"text":"the rect that has a background drawn. This allows the text to be scrolled under the gutter view for 8px before being","type":"text"},{"type":"text","text":" "},{"text":"overlapped by the gutter. It should help the textview keep the cursor visible if the user types while the cursor is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"off the leading edge of the editor."}]}],"kind":"content"}],"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/CodeEditSourceEditor\/objc(cs)NSView"],"title":"Inherits From","kind":"relationships"},{"identifiers":["doc:\/\/CodeEditSourceEditor\/objc(pl)NSAccessibilityElement","doc:\/\/CodeEditSourceEditor\/objc(pl)NSAccessibility","doc:\/\/CodeEditSourceEditor\/objc(pl)NSAnimatablePropertyContainer","doc:\/\/CodeEditSourceEditor\/objc(pl)NSAppearanceCustomization","doc:\/\/CodeEditSourceEditor\/objc(pl)NSDraggingDestination","doc:\/\/CodeEditSourceEditor\/objc(pl)NSStandardKeyBindingResponding","doc:\/\/CodeEditSourceEditor\/objc(pl)NSTouchBarProvider","doc:\/\/CodeEditSourceEditor\/objc(pl)NSUserActivityRestoring","doc:\/\/CodeEditSourceEditor\/objc(pl)NSUserInterfaceItemIdentification","doc:\/\/CodeEditSourceEditor\/objc(pl)NSCoding","doc:\/\/CodeEditSourceEditor\/objc(pl)NSObject","doc:\/\/CodeEditSourceEditor\/s7CVarArgP","doc:\/\/CodeEditSourceEditor\/s28CustomDebugStringConvertibleP","doc:\/\/CodeEditSourceEditor\/s23CustomStringConvertibleP","doc:\/\/CodeEditSourceEditor\/SQ","doc:\/\/CodeEditSourceEditor\/SH","doc:\/\/CodeEditSourceEditor\/s8SendableP"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"references":{"doc://CodeEditSourceEditor/objc(pl)NSAnimatablePropertyContainer":{"title":"AppKit.NSAnimatablePropertyContainer","identifier":"doc:\/\/CodeEditSourceEditor\/objc(pl)NSAnimatablePropertyContainer","type":"unresolvable"},"doc://CodeEditSourceEditor/s8SendableP":{"title":"Swift.Sendable","identifier":"doc:\/\/CodeEditSourceEditor\/s8SendableP","type":"unresolvable"},"doc://CodeEditSourceEditor/objc(pl)NSObject":{"title":"ObjectiveC.NSObjectProtocol","