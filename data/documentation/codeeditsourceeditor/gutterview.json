view"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"The gutter view displays line numbers that match the text view’s line indexes."},{"type":"text","text":" "},{"text":"This view is used as a scroll view’s ruler view. It sits on top of the text view so text scrolls underneath the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"gutter if line wrapping is disabled."}],"references":{"doc://codeeditsourceeditor.CodeEditSourceEditor/objc(pl)NSUserActivityRestoring":{"title":"AppKit.NSUserActivityRestoring","type":"unresolvable","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/objc(pl)NSUserActivityRestoring"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/GutterView/draw(_:)":{"kind":"symbol","type":"topic","url":"\/documentation\/codeeditsourceeditor\/gutterview\/draw(_:)","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterView\/draw(_:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"draw","kind":"identifier"},{"text":"(","kind":"text"},{"text":"NSRect","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSRect"},{"kind":"text","text":")"}],"role":"symbol","abstract":[],"title":"draw(_:)"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/CodeEditSourceEditor":{"kind":"symbol","title":"CodeEditSourceEditor","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"CodeEditSourceEditor"}],"url":"\/documentation\/codeeditsourceeditor\/codeeditsourceeditor","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/CodeEditSourceEditor","role":"symbol","navigatorTitle":[{"text":"CodeEditSourceEditor","kind":"identifier"}],"type":"topic","abstract":[{"text":"A SwiftUI View that provides source editing functionality.","type":"text"}]},"doc://codeeditsourceeditor.