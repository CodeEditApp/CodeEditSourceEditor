ewController":{"kind":"symbol","type":"topic","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/TextViewController","title":"TextViewController","role":"symbol","abstract":[{"type":"text","text":"A view controller class for managing a source editor. Uses "},{"type":"reference","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/CodeEditTextView\/TextView","isActive":true},{"text":" for input and rendering,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"tree-sitter for syntax highlighting, and TextFormation for live editing completions."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TextViewController","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"TextViewController"}],"url":"\/documentation\/codeeditsourceeditor\/textviewcontroller"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor":{"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor","role":"collection","kind":"symbol","title":"CodeEditSourceEditor","url":"\/documentation\/codeeditsourceeditor","type":"topic","abstract":[{"type":"text","text":"A code editor with syntax highlighting powered by tree-sitter."}]},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/SourceEditorState":{"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/SourceEditorState","type":"topic","url":"\/documentation\/codeeditsourceeditor\/sourceeditorstate","title":"SourceEditorState","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceEditorState"}],"navigatorTitle":[{"text":"SourceEditorState","kind":"identifier"}],"kind":"symbol","abstract":[]}}}