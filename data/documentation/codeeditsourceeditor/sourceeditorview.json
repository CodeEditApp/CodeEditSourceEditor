"}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SourceEditorState","kind":"identifier"}],"url":"\/documentation\/codeeditsourceeditor\/sourceeditorstate","title":"SourceEditorState","type":"topic"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/SourceEditorView":{"role":"collectionGroup","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/SourceEditorView","kind":"article","type":"topic","abstract":[],"title":"Source Editor View","url":"\/documentation\/codeeditsourceeditor\/sourceeditorview"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/SourceEditorConfiguration":{"navigatorTitle":[{"kind":"identifier","text":"SourceEditorConfiguration"}],"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/SourceEditorConfiguration","abstract":[{"text":"Configuration object for the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/SourceEditorView"},{"type":"text","text":". Determines appearance, behavior, layout and what features are"},{"type":"text","text":" "},{"type":"text","text":"enabled (peripherals)."}],"url":"\/documentation\/codeeditsourceeditor\/sourceeditorconfiguration","title":"SourceEditorConfiguration","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceEditorConfiguration"}],"type":"topic","kind":"symbol","role":"symbol"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/TextViewController":{"abstract":[{"text":"A view controller class for managing a source editor. Uses ","type":"text"},{"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/CodeEditTextView\/TextView","isActive":true,"type":"reference"},{"text":" for input and rendering,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"tree-sitter for syntax highlighting, and TextFormation for live editing completions."}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TextViewController"}],"title":"TextViewController","type":"topic","role":"symbol","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/TextViewController","url":"\/documentation\/codeeditsourceeditor\/textviewcontroller","navigatorTitle":[{"text":"TextViewController","kind":"identifier"}]},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/GutterView":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"GutterView"}],"kind":"symbol","title":"GutterView","navigatorTitle":[{"text":"GutterView","kind":"identifier"}],"abstract":[{"text":"The gutter view displays line numbers that match the text view’s line indexes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This view is used as a scroll view’s ruler view. It sits on top of the text view so text scrolls underneath the"},{"type":"text","text":" "},{"type":"text","text":"gutter if line wrapping is disabled."}],"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterView","url":"\/documentation\/codeeditsourceeditor\/gutterview","type":"topic","role":"symbol"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor":{"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor","url":"\/documentation\/codeeditsourceeditor","type":"topic","abstract":[{"text":"A code editor with syntax highlighting powered by tree-sitter.","type":"text"}],"kind":"symbol","title":"CodeEditSourceEditor","role":"collection"}}}