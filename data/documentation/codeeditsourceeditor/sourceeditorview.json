ifier"}]},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/SourceEditorState":{"url":"\/documentation\/codeeditsourceeditor\/sourceeditorstate","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/SourceEditorState","navigatorTitle":[{"text":"SourceEditorState","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SourceEditorState"}],"role":"symbol","type":"topic","abstract":[],"kind":"symbol","title":"SourceEditorState"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/GutterView":{"title":"GutterView","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/GutterView","role":"symbol","url":"\/documentation\/codeeditsourceeditor\/gutterview","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"GutterView","kind":"identifier"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The gutter view displays line numbers that match the text view’s line indexes."},{"text":" ","type":"text"},{"type":"text","text":"This view is used as a scroll view’s ruler view. It sits on top of the text view so text scrolls underneath the"},{"type":"text","text":" "},{"type":"text","text":"gutter if line wrapping is disabled."}],"navigatorTitle":[{"kind":"identifier","text":"GutterView"}]},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/TextViewController":{"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TextViewController","kind":"identifier"}],"identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/TextViewController","navigatorTitle":[{"text":"TextViewController","kind":"identifier"}],"type":"topic","url":"\/documentation\/codeeditsourceeditor\/textviewcontroller","role":"symbol","title":"Text