se","type":"codeVoice"},{"type":"text","text":")."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"inwards","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":", the text will be unindented."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"inwards"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", the text will be indented.","type":"text"}]}]}]}],"name":"inwards"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"This function modifies the indentation of the selected lines based on the current "},{"code":"indentOption","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It handles both indenting (moving text to the right) and unindenting (moving text to the left), with the"},{"text":" ","type":"text"},{"type":"text","text":"behavior depending on whether "},{"type":"codeVoice","code":"inwards"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"false"},{"text":". It processes the ","type":"text"},{"code":"indentOption","type":"codeVoice"},{"type":"text","text":" to apply the"},{"text":" ","type":"text"},{"type":"text","text":"correct number of spaces or tabs."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The function operates on "},{"type":"strong","inlineContent":[{"type":"text","text":"one-to-many selections"}]},{"type":"text","text":", where each selection can affect "},{"inlineContent":[{"text":"one-to-many lines","type":"text"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Each of those lines will be modified accordingly.","type":"text"}]},{"type":