rent selections in the "},{"type":"codeVoice","code":"textView"},{"type":"text","text":". It performs a reverse iteration"},{"type":"text","text":" "},{"type":"text","text":"over the text selections, ensuring that edits do not affect the later selections."}]}],"name":"Important"}]}],"abstract":[{"type":"text","text":"Handles indentation and unindentation for selected lines in the text view."}],"references":{"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/TextViewController/handleIndent(inwards:)":{"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"handleIndent"},{"text":"(","kind":"text"},{"text":"inwards","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"role":"symbol","abstract":[{"type":"text","text":"Handles indentation and unindentation for selected lines in the text view."}],"title":"handleIndent(inwards:)","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/TextViewController\/handleIndent(inwards:)","url":"\/documentation\/codeeditsourceeditor\/textviewcontroller\/handleindent(inwards:)","type":"topic"},"doc://codeeditsourceeditor.CodeEditSourceEditor/documentation/CodeEditSourceEditor/TextViewController":{"kind":"symbol","type":"topic","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/TextViewController","title":"TextViewController","role":"symbol","abstract":[{"type":"text","text":"A view controller class for managing a source editor. Uses "},{"type":"reference","identifier":"doc:\/\/codeeditsourceeditor.CodeEditSourceEditor\/documentation\/CodeEditSourceEditor\/CodeEditTextView\/TextView","isActive":true},{"text":" for input and rendering,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"tree-sitter for syntax highlighting, and TextFormation